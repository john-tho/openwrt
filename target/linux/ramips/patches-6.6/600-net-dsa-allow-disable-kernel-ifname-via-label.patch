From b6ddb010455569cd02dc6ada92e9c805d739161c Mon Sep 17 00:00:00 2001
From: John Thomson <git@johnthomson.fastmail.com.au>
Date: Sun, 23 Jun 2024 09:25:33 +1000
Subject: [PATCH] net: dsa: allow disable kernel ifname via label

With only DSA supporting network interface names set by DSA label,
an interface can be brought up (before DSA port) with an autogenerated
name that clashes with a DSA label. DSA then refuses to bring up that port.
This DTS port label is the simplest place to detail intended device names,
so introduce a port level property which skips DSA applying the ifname:
disable-kernel-ifname;

Link: https://lore.kernel.org/netdev/20240608014724.2541990-1-git@johnthomson.fastmail.com.au/

Signed-off-by: John Thomson <git@johnthomson.fastmail.com.au>
---
 net/dsa/dsa.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

--- a/net/dsa/dsa.c
+++ b/net/dsa/dsa.c
@@ -1263,7 +1263,10 @@ static int dsa_port_parse_of(struct dsa_
 	if (link)
 		return dsa_port_parse_dsa(dp);
 
-	return dsa_port_parse_user(dp, name);
+	if (!of_property_read_bool(dn, "disable-kernel-ifname"))
+		return dsa_port_parse_user(dp, name);
+	else
+		return dsa_port_parse_user(dp, NULL);
 }
 
 static int dsa_switch_parse_ports_of(struct dsa_switch *ds,
